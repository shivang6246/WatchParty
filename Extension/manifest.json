{
  "manifest_version": 3,
  "name": "WatchParty",
  "description": "Watch YouTube together in sync with friends.",
  "version": "1.0.1",

  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "http://localhost:8080/*",
    "https://*.youtube.com/*",
    "https://*.netflix.com/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "WatchParty"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.netflix.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}